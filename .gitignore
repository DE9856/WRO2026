# ==========================================
# Python Cache / Compiled Files
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Virtual Environment
# ==========================================
venv/
.env/
env/
ENV/

# ==========================================
# Environment Variables / Secrets
# ==========================================
.env
.env.*
!.env.example

# ==========================================
# VS Code / IDE
# ==========================================
.vscode/
.idea/
*.swp
*.swo

# ==========================================
# Logs
# ==========================================
*.log
logs/

# ==========================================
# Temporary Files
# ==========================================
temp/
tmp/
*.tmp

# ==========================================
# OS Files
# ==========================================
.DS_Store
Thumbs.db

# ==========================================
# Jupyter
# ==========================================
.ipynb_checkpoints/

# ==========================================
# Testing / Coverage
# ==========================================
.pytest_cache/
.coverage
htmlcov/

# ==========================================
# Type Checkers / Linters
# ==========================================
.mypy_cache/
.ruff_cache/

# ==========================================
# Build Files
# ==========================================
build/
dist/
*.egg-info/

# ==========================================
# OpenCV Captures / Output Media
# ==========================================
captures/
recordings/
output/
debug/
screenshots/

# Ignore generated media
*.avi
*.mp4
*.mov
*.mkv

# Ignore generated images
*.png
*.jpg
*.jpeg

# BUT keep manually added assets
!assets/
!dataset/

# ==========================================
# AI / Model Files
# ==========================================
models/
weights/
checkpoints/

*.pt
*.pth
*.onnx
*.engine
*.tflite
*.h5

# ==========================================
# Misc
# ==========================================
*.bak
*.old